# Anthropic Claude API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Which Claude model to use for answer generation
CLAUDE_MODEL=claude-sonnet-4-5

# Local sentence-transformers model used for embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Where Chroma persists its local vector index
CHROMA_PERSIST_DIR=./data/chroma_db

# Chunking parameters
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=75

# Retrieval
TOP_K_CHUNKS=5

# CORS - comma separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
